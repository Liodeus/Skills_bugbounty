# Python build artifacts
__pycache__/
*.py[cod]

# Generated by playwright-chrome/setup.sh (machine-local absolute paths) — do not commit
playwright-chrome/configs/user*.json

# Runtime logs
/tmp/
*.log

# YesWeHack program catalog (generated by SKILLS/yeswehack-programs) + cached token
data/
**/.token.json

# Node deps for the Playwright XSS-confirm oracle (installed by install_tools.sh)
node_modules/
package-lock.json

# Python venv for the web dashboard
autohunt/web/.venv/

# GEPA prompt-optimizer: venv + optimizer outputs (optimized prompts await human review)
optimize/.venv/
optimize/out/

# Local secrets (.env.example is the tracked template)
.env
