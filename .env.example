# autohunt environment — copy to .env and fill in:
#     cp .env.example .env && $EDITOR .env
# Then either export into your shell:  set -a && source .env && set +a
# …or just run ./run.sh — it auto-sources .env if present.
#
# .env is gitignored; .env.example is the tracked template. Never commit real secrets.

# --- YesWeHack catalog auth (yeswehack_programs.py) ---
# Used to pull the program catalog (incl. private programs). The 6-digit TOTP is
# prompted interactively at runtime if 2FA is enabled. Leave blank to be prompted,
# or use --public-only to skip login entirely.
YWH_EMAIL=
YWH_PASSWORD=

# --- Notifications (optional but recommended) ---
# Discord webhook for verified findings, unverified-lead digests, and monitor alerts.
DISCORD_WEBHOOK_URL=

# --- Optional ---
# Override the python interpreter run.sh uses (default python3).
# PYTHON=python3

# --- Auth model (do not set unless you mean it) ---
# autohunt drives `claude -p` on your Claude SUBSCRIPTION (the `claude` login), NOT the API.
# If ANTHROPIC_API_KEY is set it is IGNORED for child sessions unless you pass --use-api.
# ANTHROPIC_API_KEY=
